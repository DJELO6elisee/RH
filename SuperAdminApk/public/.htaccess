# Force le rechargement des fichiers JavaScript
<IfModule mod_headers.c>
    # Désactiver le cache pour les fichiers JS et CSS en développement
    <FilesMatch "\.(js|css)$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires 0
    </FilesMatch>
</IfModule>

